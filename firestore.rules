rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' | 'admin')
    //   - createdAt: timestamp (required)
    //
    // Collection: hazards
    // Document ID: {hazardId}
    // Fields:
    //   - id: string (required)
    //   - type: string (required, enum)
    //   - description: string (required, < 1000 chars)
    //   - severity: string (required, 'low' | 'medium' | 'high')
    //   - location: map (required)
    //     - latitude: number
    //     - longitude: number
    //     - address: string
    //   - userId: string (required)
    //   - createdAt: timestamp (required)
    //   - imageUrl: string (optional)
    //   - videoUrl: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nikashjaipal2008@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'role', 'createdAt'];
      let allowedFields = ['uid', 'email', 'role', 'createdAt', 'displayName', 'photoURL', 'disabilities', 'mobilityAids', 'setupComplete', 'phoneNumber', 'accessibilitySettings', 'fullName', 'emergencyContactName', 'emergencyContactPhone', 'preferences', 'isVolunteer'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp &&
             (!('disabilities' in data) || data.disabilities is list) &&
             (!('mobilityAids' in data) || data.mobilityAids is list) &&
             (!('preferences' in data) || data.preferences is map);
    }

    function isValidHazard(data) {
      return data.keys().hasAll(['id', 'type', 'description', 'severity', 'location', 'userId', 'createdAt']) &&
             data.id is string &&
             data.type in ['uneven-path', 'construction', 'no-elevator', 'crowded', 'poor-lighting', 'other'] &&
             data.description is string && data.description.size() < 1000 &&
             data.severity in ['low', 'medium', 'high'] &&
             data.location is map &&
             data.location.latitude is number &&
             data.location.longitude is number &&
             data.userId is string &&
             data.createdAt is timestamp;
    }

    function isValidEmergencyAlert(data) {
      let requiredFields = ['userId', 'timestamp', 'status'];
      let allowedFields = ['userId', 'userEmail', 'userName', 'location', 'timestamp', 'status', 'type'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId is string &&
             data.timestamp is timestamp &&
             data.status in ['active', 'resolved', 'cancelled'] &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('userName' in data) || data.userName is string) &&
             (!('location' in data) || data.location is map) &&
             (!('type' in data) || data.type is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isOwner(userId) ? request.resource.data.role == resource.data.role : true);
      allow delete: if isAdmin();
    }

    match /hazards/{hazardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidHazard(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && isValidHazard(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /emergency_alerts/{alertId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidEmergencyAlert(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && isValidEmergencyAlert(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.timestamp == resource.data.timestamp;
      allow delete: if isAdmin();
    }
  }
}
