{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." },
        "disabilities": { "type": "array", "items": { "type": "string" }, "description": "List of selected disabilities." },
        "setupComplete": { "type": "boolean", "description": "Whether the user has completed the profile setup." },
        "phoneNumber": { "type": "string", "description": "The user's phone number." },
        "accessibilitySettings": { "type": "object", "description": "User's accessibility preferences." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "HazardReport": {
      "title": "HazardReport",
      "description": "Represents a reported hazard.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the report." },
        "type": { "type": "string", "enum": ["uneven-path", "construction", "no-elevator", "crowded", "poor-lighting", "other"], "description": "The type of hazard." },
        "description": { "type": "string", "description": "A detailed description of the hazard." },
        "severity": { "type": "string", "enum": ["low", "medium", "high"], "description": "The severity level." },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          },
          "required": ["latitude", "longitude"]
        },
        "userId": { "type": "string", "description": "The ID of the user who reported it." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created." },
        "imageUrl": { "type": "string", "description": "Optional image URL." },
        "videoUrl": { "type": "string", "description": "Optional video URL generated by Veo." }
      },
      "required": ["id", "type", "description", "severity", "location", "userId", "createdAt"]
    },
    "EmergencyAlert": {
      "title": "EmergencyAlert",
      "description": "Represents an emergency SOS alert.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who triggered the alert." },
        "userEmail": { "type": "string", "description": "The user's email." },
        "userName": { "type": "string", "description": "The user's display name." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the alert was triggered." },
        "status": { "type": "string", "enum": ["active", "resolved", "cancelled"], "description": "The status of the alert." },
        "type": { "type": "string", "description": "The type of emergency." }
      },
      "required": ["userId", "timestamp", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/hazards/{hazardId}": {
      "schema": "HazardReport",
      "description": "Collection of hazard reports."
    },
    "/emergency_alerts/{alertId}": {
      "schema": "EmergencyAlert",
      "description": "Collection of emergency SOS alerts."
    }
  }
}
